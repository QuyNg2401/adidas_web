PORT=4000
NODE_ENV=development

# XAMPP MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stride
DB_POOL_SIZE=10

# Auth
JWT_SECRET="change-me"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# Browser URL (redirect sau OAuth Google)
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth — tạo credential OAuth 2.0 Web application trên Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

